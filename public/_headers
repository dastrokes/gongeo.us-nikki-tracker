# Match all images served through the Netlify Image CDN
/.netlify/images/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Cache all static assets heavily
/_nuxt/*
  Cache-Control: public, max-age=31536000, immutable

# Default caching for HTML (no cache)
/
  Cache-Control: public, max-age=0, must-revalidate

# Allow CORS for images
/images/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable
